# Aegis environment variables template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control. The .gitignore enforces this.

# Groq API key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI API key (only if you swap to OpenAI later)
# OPENAI_API_KEY=your_openai_key_here

# Optional: Anthropic API key (only if you swap to Anthropic later)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Model configuration
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store path (local, gitignored)
CHROMA_PERSIST_DIR=./chroma_db